rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función de ayuda para verificar si está autenticado
    function isAuth() {
      return request.auth != null;
    }

    // Regla base para el entorno de pruebas/desarrollo final
    // Para producción estricta, estas reglas deben refinarse por colección
    // Por ahora requerimos que el usuario haya iniciado sesión (Auth anónimo o email/password)
    match /{document=**} {
      allow read, write: if isAuth();
    }
    
    // NOTA: Cuando se tenga el sistema de Authentication conectado 1 a 1 con Firebase Auth, se pueden habilitar reglas como:
    // match /usuarios/{userId} {
    //   allow read: if isAuth();
    //   allow write: if request.auth.uid == userId || get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.role == "admin";
    // }
  }
}
