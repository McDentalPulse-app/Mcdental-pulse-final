{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "api/aprobar-rostro.js": {
      "includeFiles": "api/models/**",
      "excludeFiles": "node_modules/onnxruntime-node/bin/napi-v6/{darwin,win32}/**",
      "maxDuration": 30,
      "memory": 2048
    },
    "api/enrolar-rostro.js": {
      "includeFiles": "api/models/**",
      "excludeFiles": "node_modules/onnxruntime-node/bin/napi-v6/{darwin,win32}/**",
      "maxDuration": 30,
      "memory": 2048
    },
    "api/checar.js": {
      "includeFiles": "api/models/**",
      "excludeFiles": "node_modules/onnxruntime-node/bin/napi-v6/{darwin,win32}/**",
      "maxDuration": 30,
      "memory": 2048
    },
    "api/limpiar-fotos.js": {
      "maxDuration": 60
    },
    "api/recordatorio-encuestas.js": {
      "maxDuration": 30
    },
    "api/revisar-tickets.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/limpiar-fotos",
      "schedule": "17 4 * * *"
    },
    {
      "path": "/api/recordatorio-encuestas",
      "schedule": "0 15 * * 2,4,5"
    },
    {
      "path": "/api/revisar-tickets",
      "schedule": "*/15 * * * *"
    }
  ]
}
