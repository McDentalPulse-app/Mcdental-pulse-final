# Supabase (variables públicas de inicialización del SDK — no son secretos)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# App
VITE_APP_NAME=McDental Pulse
VITE_APP_ENV=development

# ──────────────────────────────────────────────────────────────────────────────
# IA (Gemini) — SERVIDOR, no cliente. Sin prefijo VITE_ → no entra al bundle.
# La consume el proxy serverless api/gemini.js.
# Local: ponla en .env.local. Producción: Vercel → Settings → Environment Variables.
GEMINI_API_KEY=
# ──────────────────────────────────────────────────────────────────────────────

# ──────────────────────────────────────────────────────────────────────────────
# SERVIDOR/SCRIPTS únicamente — NUNCA con prefijo VITE_, nunca al bundle cliente.
# service_role bypasea RLS: solo la usan las Edge Functions (supabase secrets set)
# y scripts/migrate-firestore-to-supabase.mjs (local, no productivo).
SUPABASE_SERVICE_ROLE_KEY=

# Solo para scripts/migrate-firestore-to-supabase.mjs (migración one-shot).
FIREBASE_SERVICE_ACCOUNT_PATH=
FIREBASE_STORAGE_BUCKET=
# ──────────────────────────────────────────────────────────────────────────────

# Integración con MCTIC (sistema de tickets de TI). Server-side, no VITE_.
# La consume el proxy serverless api/soporte-ticket.js.
MCTIC_API_URL=https://mctic.tu-dominio.com
MCTIC_INTEGRATION_KEY=
