# Firebase (variables públicas de inicialización del SDK — no son secretos)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# App
VITE_APP_NAME=McDental Pulse
VITE_APP_ENV=development

# ──────────────────────────────────────────────────────────────────────────────
# IA (Gemini) — SERVIDOR, no cliente. Sin prefijo VITE_ → no entra al bundle.
# La consume el proxy serverless api/gemini.js.
# Local: ponla en .env.local. Producción: Vercel → Settings → Environment Variables.
GEMINI_API_KEY=
# ──────────────────────────────────────────────────────────────────────────────
